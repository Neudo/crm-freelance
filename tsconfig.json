{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/ts/*"]
        },
        "types": ["vite/client"]
    },
    "include": [
        "resources/ts/**/*",
        "resources/ts/**/*.tsx",
        "resources/ts/**/*.ts"
    ],
    "exclude": ["node_modules", "public", "storage", "vendor"]
}
